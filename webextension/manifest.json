{
  "manifest_version": 2,
  "name": "pw",
  "version": "0.2.0",
  "description": "Fill logins from the pw password manager, without the clipboard.",
  "browser_specific_settings": {
    "gecko": {
      "id": "pw@staldal.nu",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "permissions": [
    "nativeMessaging",
    "activeTab",
    "menus"
  ],
  "background": {
    "scripts": ["background.js"],
    "persistent": true
  },
  "icons": {
    "16": "icons/pw16.png",
    "32": "icons/pw32.png",
    "48": "icons/pw48.png",
    "96": "icons/pw96.png"
  },
  "browser_action": {
    "default_title": "Fill login with pw",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/pw16.png",
      "32": "icons/pw32.png",
      "48": "icons/pw48.png",
      "96": "icons/pw96.png"
    }
  },
  "commands": {
    "_execute_browser_action": {
      "suggested_key": {
        "default": "Ctrl+Alt+L"
      },
      "description": "Fill login with pw"
    }
  }
}
